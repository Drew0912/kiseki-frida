{
  "name": "kiseki-frida",
  "version": "1.0.0",
  "description": "Frida script for various Kiseki/Trails PC games.",
  "private": true,
  "main": "src/main.ts",
  "scripts": {
    "build": "npm run build_ed85",
    "test": "frida-compile --tsconfig tsconfig.json src/main.ts -o out.js -c",
    "build_ed85": "frida-compile --tsconfig tsconfig.json src/ed8/ed85/main.ts -o \"out\\ed85\\hnk.js\" -c",
    "watch_ed85": "frida-compile --tsconfig tsconfig.json src/ed8/ed85/main.ts -o \"out\\ed85\\hnk.js\" -w"
  },
  "devDependencies": {
    "@types/frida-gum": "^18.4.2",
    "@types/node": "^18.16.0",
    "@types/sprintf-js": "^1.1.4",
    "frida-compile": "^10.2.5"
  },
  "dependencies": {
    "sprintf-js": "^1.1.3"
  }
}
